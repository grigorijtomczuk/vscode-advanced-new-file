{
  "name": "advanced-new-file-plus",
  "displayName": "advanced-new-file-plus",
  "version": "1.4.9",
  "description": "Create files anywhere in your workspace with keyboard (advanced-new-file fork)",
  "categories": [
    "Keymaps",
    "Other"
  ],
  "homepage": "https://github.com/grigorijtomczuk/advanced-new-file-plus",
  "repository": {
    "type": "git",
    "url": "https://github.com/grigorijtomczuk/advanced-new-file-plus.git"
  },
  "publisher": "grigorijtomczuk",
  "main": "./out/src/extension",
  "scripts": {
    "compile": "tsc -watch -p ./",
    "lint": "eslint src/** test/**",
    "package": "vsce package",
    "release": "vsce publish",
    "test": "vscode-test",
    "vscode:prepublish": "tsc -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "extension.advancedNewFile",
        "title": "Advanced New File"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AdvancedNewFile configuration",
      "properties": {
        "advancedNewFile.exclude": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "boolean"
          },
          "default": null,
          "description": "Directories to ignore in auto-complete"
        },
        "advancedNewFile.showInformationMessages": {
          "type": "boolean",
          "default": true,
          "description": "Control whether top-bar notifications display"
        },
        "advancedNewFile.convenienceOptions": {
          "type": "array",
          "default": [
            "last",
            "current",
            "root"
          ],
          "description": "Convenience options display at the top of the list. Control which ones you see and in what order."
        },
        "advancedNewFile.expandBraces": {
          "type": "boolean",
          "default": false,
          "description": "Whether braces should be expanded to multiple paths (such as {test1,test2}.js creating two files, test1.js and test2.js"
        }
      }
    },
    "keybindings": [
      {
        "command": "extension.advancedNewFile",
        "key": "alt+ctrl+n",
        "mac": "alt+cmd+n"
      }
    ]
  },
  "activationEvents": [
    "onCommand:extension.advancedNewFile"
  ],
  "dependencies": {
    "braces": "^3.0.2",
    "ignore": "^7.0.5",
    "mkdirp": "^0.5.1",
    "vscode-cache": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chai": "^3.4.34",
    "@types/chai-as-promised": "0.0.29",
    "@types/chai-spies": "0.0.0",
    "@types/fs-extra": "0.0.35",
    "@types/mkdirp": "^0.3.29",
    "@types/mocha": "^2.2.32",
    "@types/node": "^22.19.15",
    "@types/proxyquire": "^1.3.27",
    "@types/vscode": "~1.105",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^3.5.0",
    "chai-as-promised": "^6.0.0",
    "chai-spies": "^0.7.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "fs-extra": "^1.0.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "mocha": "^2.5.3",
    "ovsx": "0.1.0-next.a9154dc",
    "prettier": "3.8.1",
    "proxyquire": "^1.7.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vsce": "^2.15.0"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "icon": "icon.png"
}
